{
  "name": "foggy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:network": "cd frontend && pnpm dev -- --hostname 0.0.0.0",
    "frontend": "cd frontend && pnpm start",

    "backend:dev": "cd backend && pnpm start:dev",
    "backend": "cd backend && pnpm start",

    "sync:dev": "cd sync_service && pnpm dev",
    "sync": "cd sync_service && pnpm start",

    "dev": "concurrently \"pnpm run frontend:dev\" \"pnpm run backend:dev\" \"pnpm run sync:dev\"",
    "start": "concurrently \"pnpm run frontend\" \"pnpm run backend\" \"pnpm run sync\"",

    "docker": "docker-compose up --build",

    "e2e": "pnpm exec playwright test --workers=1",
    "e2e-ui": "pnpm exec playwright test --ui",
    "performance": "npx playwright test -g \"Performance benchmark\" --project=chromium --headed --repeat-each=10 --workers=1",
    "performance-headless": "npx playwright test -g \"Performance benchmark\" --project=chromium --repeat-each=10 --workers=1"
  },
  "workspaces": [
    "frontend",
    "backend",
    "sync_service"
  ],
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "axios": "^1.13.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "overrides": {
      "@internationalized/date": "3.11.0"
    }
  },
  "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}
